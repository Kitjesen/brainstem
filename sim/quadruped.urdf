    <child link="fr_hip_Link"/>
    <origin xyz="0.2395 -0.0646 0.0807" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-0.8" upper="0.8" effort="50" velocity="10"/>
