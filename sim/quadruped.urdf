<?xml version="1.0" encoding="utf-8"?>
<robot name="quadruped">

  <!-- ═══ Base Link ═══ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0108 0.0073 0.0758" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><mesh filename="meshes/base_link.STL"/></geometry>
      <material name="body"><color rgba="0.25 0.25 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.44 0.24 0.11"/></geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ═══ FR (Front Right) ═══ -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <joint name="fr_hip_joint" type="revolute">
